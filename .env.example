# GRaC Environment Configuration
# Copy this to .env and fill in your actual values

# API Keys — set at least one for LLM functionality
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here  # Free at build.nvidia.com, no credit card

# Sector Configuration
ACTIVE_SECTOR=cybersecurity
ENABLE_MULTI_SECTOR=False
# ACTIVE_SECTORS=cybersecurity,fintech  (only if ENABLE_MULTI_SECTOR=True)

# API Server
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=False

# LLM Configuration — Multi-Provider
# LLM_PROVIDER=auto            # "anthropic", "openai", "nvidia", or "auto" (auto = first available)
# LLM_FALLBACK_ENABLED=True     # Try next provider if primary fails
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# Embedding Configuration
# EMBEDDING_PROVIDER=auto      # "local", "openai", "nvidia", or "auto"
#   local = sentence-transformers (offline, ~90MB download)
#   openai = uses OPENAI_API_KEY
#   nvidia = uses NVIDIA_API_KEY (free, no download needed)
#   auto = tries NVIDIA first, then OpenAI, then local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_API_MODEL=nvidia/nv-embed-qa-4

# PDF Processing
PDF_CHUNK_SIZE=500
PDF_OVERLAP=100

# Agent Configuration
AGENT_TIMEOUT=300
AGENT_RETRY_ATTEMPTS=3

# Database
DATABASE_URL=sqlite:///./data/grac.db

# Logging
LOG_LEVEL=INFO

# Confidence Thresholds
MIN_RETRIEVAL_CONFIDENCE=0.6
MIN_ANSWER_CONFIDENCE=0.7
